---
import Layout from './../../../layouts/Layout.astro';
import PostCard from './../../../components/PostCard.astro';
import Pagination from './../../../components/Pagination.astro'

//utils
import { formatBlogPosts } from './../../../js/utils';

//import all posts with .md
export async function getStaticPaths({paginate}) {
    const newPosts = Object.values(import.meta.glob("./../../blog/posts/*.md", {eager: true}));
    //const allPosts = import.meta.glob("./*.md");
    //console.log("~ newPosts", newPosts)
    const formattedPosts = await formatBlogPosts(newPosts)

    const uniqueTags = [...new Set(formattedPosts.map((post: any) => post.frontmatter.tags).flat())];
    console.log("~ uniqueTags", uniqueTags)
    
    const filteredPostsWithPagination = uniqueTags.flatMap((tag) => {
        const filteredPosts = formattedPosts.filter((post: any) => post.frontmatter.tags.includes(tag));
        return paginate(filteredPosts, {
            params: { tags: tag },
            props: { posts: filteredPosts },
        });
    });

    return filteredPostsWithPagination;
;}

//console.log("~ AllPosts", allPosts)
const {page} = Astro.props as { page: { data: any[] } };
const {tags} = Astro.params;
//console.log(Astro.props)
---
<Layout title={`Posts tagged with "${tags}"`} description='Blogs' sideBarActiveItemID='blog'>
    <ul>
        {
            page.data.map((post) => (
            <PostCard 
                frontmatter={post.frontmatter}
                post_url={post.url}
            >
            </PostCard>
            ))
           
        }

        <!--Div for pagination -->
        <Pagination
            page={page}
        ></Pagination> 
       
    </ul>
</Layout>

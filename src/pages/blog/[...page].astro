---
import Layout from './../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro'
import Filter from '../../components/Filter.astro';

//utils
import { formatBlogPosts } from '../../js/utils';
import { getAllPosts } from '../../js/postUtils.js';
import type { GetStaticPaths } from 'astro';

//import all posts with .md
export const getStaticPaths:GetStaticPaths = async ({paginate}) => {
    const allPosts = getAllPosts();
    //const allPosts = import.meta.glob("./*.md");
    //console.log("~ allPosts", allPosts)
    const formattedPosts = await formatBlogPosts(allPosts)
    //console.log(allPosts.map((post:any) => post.frontmatter.tags))
    return paginate(formattedPosts, {
        pageSize: 5,
    });

}

const allPosts = getAllPosts();

//console.log("~ AllPosts", allPosts.map((post:any) => post.frontmatter.tags));

const tags = [...new Set(allPosts.map((post:any) => post.frontmatter.tags).flat())];

//console.log("~ tags", tags);

const {page} = Astro.props as { page: { data: any[] } };
//console.log(Astro.props)
---
<Layout title="Blogs" description='Blogs' sideBarActiveItemID='blog'>
    <Filter
        tags={tags}
        activeTag={''}
    ></Filter>

    <ul>
        {
            page.data.map((post) => (
            <PostCard 
                frontmatter={post.frontmatter}
                post_url={post.url}
            >
            </PostCard>
            ))
           
        }

        <!--Div for pagination -->
        <Pagination
            page={page}
        ></Pagination> 
       
    </ul>
</Layout>
